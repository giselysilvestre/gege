# Copie para backend/.env e frontend/.env.local (dois arquivos separados).

# =============================================================================
# Backend — arquivo: backend/.env
# =============================================================================
# Project URL (só https://xxxx.supabase.co — NÃO use link do dashboard/SQL).
SUPABASE_URL=https://xxxx.supabase.co

# Chave service_role (Legacy API keys). Texto longo (eyJ...), NÃO é URL.
SUPABASE_SERVICE_ROLE_KEY=

PORT=4000
# Em produção não publique esta porta na internet: use o rewrite /gege-api do Next no mesmo host
# ou rede privada. O backend usa service_role e não valida JWT do recrutador.

# Produção: origem do frontend (evita CORS aberto). Ex.: https://app.seudominio.com
# CORS_ORIGIN=

# =============================================================================
# Frontend — arquivo: frontend/.env.local
# =============================================================================
# Obrigatórias para login, middleware e Server Components (Supabase).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Só no servidor Next (nunca NEXT_PUBLIC_*). Usada em rotas/API que precisam bypass RLS pontual.
# Mesmo valor da service_role do projeto — NÃO commite valores reais.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: inclui objeto `debug` nas respostas de GET /api/candidatos/list (só para diagnóstico).
# GEGE_API_DEBUG=true

# Dev: porta do Express se diferente de 4000 (next.config.ts usa para o rewrite /gege-api).
# GEGE_BACKEND_PORT=4000

# =============================================================================
# gege-cv-processor — arquivo: gege-cv-processor/.env
# =============================================================================
# Chave da Anthropic (Claude API).
# ANTHROPIC_API_KEY=
#
# Conta do Gmail usada nos scripts.
# GMAIL_USER=me
