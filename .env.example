# Copie para backend/.env e frontend/.env.local conforme indicado no README.

# --- Backend (backend/.env) ---
# URL do projeto Supabase (Settings → API → Project URL)
SUPABASE_URL=https://xxxx.supabase.co

# Chave service_role — somente no servidor. Nunca commite nem exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Porta da API Express
PORT=4000

# Origem do Next.js no CORS (desenvolvimento)
CORS_ORIGIN=http://localhost:3000

# --- Frontend (frontend/.env.local) ---
# URL base da API (sem barra no final). Usada no browser e nas Server Actions.
NEXT_PUBLIC_API_URL=http://localhost:4000
