# Copie para backend/.env e frontend/.env.local.

# --- Backend (backend/.env) ---
# Obrigatório: Project URL (só https://xxxx.supabase.co — NÃO use link do dashboard/SQL).
SUPABASE_URL=https://xxxx.supabase.co

# Obrigatório: chave service_role (Legacy API keys). Texto longo (eyJ...), NÃO é URL.
SUPABASE_SERVICE_ROLE_KEY=

PORT=4000

# --- Frontend (frontend/.env.local) ---
# Dev: o browser chama /gege-api → Next faz proxy para o Express (sem CORS).
# Só precisa disso no servidor Next (Server Components / Server Actions):
GEGE_API_URL=http://127.0.0.1:4000

# Produção: URL pública da API (quando não há proxy /gege-api).
# NEXT_PUBLIC_API_URL=https://api.seudominio.com
